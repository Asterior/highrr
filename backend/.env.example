# REQUIRED - JWT signing secret, minimum 32 characters
SECRET_KEY=

# REQUIRED - PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# JWT algorithm
ALGORITHM=HS256

# Access token expiry in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Refresh token expiry in days
REFRESH_TOKEN_EXPIRE_DAYS=7

# Comma-separated allowed CORS origins (no spaces)
CORS_ORIGINS=http://localhost:5173

# development or production
ENVIRONMENT=development

# Directory for uploaded files (relative to backend/)
UPLOAD_DIR=uploads

# ATS and chatbot use Ollama exclusively
# Model name to use (must be pulled in Ollama)
QWEN_MODEL=qwen2.5:7b

# Ollama server base URL
OLLAMA_BASE_URL=http://localhost:11434

# Rate limiting (requests per window)
RATE_LIMIT_LOGIN=5
RATE_LIMIT_REGISTER=3

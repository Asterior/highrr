# Database Configuration (Supabase PostgreSQL)
# Replace with your actual credentials
DATABASE_URL=postgresql://postgres.username:password@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.username:password@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres

# JWT Configuration (Security)
# Generate a secure secret key - min 32 characters recommended
SECRET_KEY=your-super-secret-key-change-this-in-production

# JWT Token Settings
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Application Settings
DEBUG=false
ENVIRONMENT=production

# Gemini ATS AI Settings
GEMINI_API_KEY=your-gemini-api-key
ENABLE_GEMINI_ATS=true
GEMINI_ATS_TOP_N=3

# API Settings
CORS_ORIGINS=["http://localhost:5173","http://localhost:8080","http://127.0.0.1:8080"]
